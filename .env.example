# Database Configuration
DB_USER=postgres
# REQUIRED: Set a strong random password. Generate with: openssl rand -base64 24
DB_PASSWORD=
DB_NAME=osint_crm_db
DB_HOST=db
DB_PORT=5432

# Application Configuration
NODE_ENV=development
PORT=3001

# Security
# REQUIRED: Minimum 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Frontend URL for CORS (required in production)
FRONTEND_URL=http://localhost:8080

# Geocoding — Photon runs as a Docker service, no config needed.
# Override only if running Photon separately.
# PHOTON_URL=http://photon:2322

# Add JWT_SECRET for future authentication implementation
# JWT_SECRET=your-secret-key-here

# API Keys (if needed for external services)
# GEOCODING_API_KEY=your-api-key-here
